set dotenv-load := false

_default:
    @just --list

email:
	sops -d --output secrets_decrypted/dovecot.yml secrets/dovecot.yml
	sops -d --output secrets_decrypted/fetchmail.yml secrets/fetchmail.yml
	kubectl delete -f secrets_decrypted/dovecot.yml
	kubectl delete -f secrets_decrypted/fetchmail.yml
	kubectl delete -f email/deployment.yml
  

nextcloud:
	kustomize build --enable-alpha-plugins --enable-exec --load-restrictor LoadRestrictionsNone nextcloud/ | KUBECTL_APPLYSET=true kubectl apply -f - --server-side --prune --applyset=configmaps/nextcloud-applyset --namespace=default


nextcloud_resync_file:
	kubectl exec -t $(shell kubectl get pods -n default -l app=nextcloud -o json | jq .items[].metadata.name) -- /usr/bin/occ files:scan --all


backup:
	sops -d --output secrets_decrypted/backup_credentials.yml secrets/backup_credentials.yml
	kubectl apply -f secrets_decrypted/backup_credentials.yml
	kubectl apply -f backup/backup-cron.yml
	kubectl apply -f backup/backup-minio.yml

webhook:
	kustomize build --enable-alpha-plugins --enable-exec --load-restrictor LoadRestrictionsNone webhook/ | KUBECTL_APPLYSET=true kubectl apply -f - --server-side --prune --applyset=configmaps/webhook-applyset --namespace=default

