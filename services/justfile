stalwart:
	kustomize build --enable-alpha-plugins --enable-exec --load-restrictor LoadRestrictionsNone stalwart/ | KUBECTL_APPLYSET=true kubectl apply -f - --server-side --prune --applyset=configmaps/stalwart-applyset --namespace=default

warpgate:
	kubectl apply -f app/warpgate.yml

blog:
	kustomize build --enable-alpha-plugins --enable-exec --load-restrictor LoadRestrictionsNone blog/ | KUBECTL_APPLYSET=true kubectl apply -f - --server-side --prune --applyset=configmaps/blog-applyset --namespace=default

dashy:
	kustomize build --enable-alpha-plugins --enable-exec --load-restrictor LoadRestrictionsNone dashy/ | KUBECTL_APPLYSET=true kubectl apply -f - --server-side --prune --applyset=configmaps/dashy-applyset --namespace=default

